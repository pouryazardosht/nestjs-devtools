{
  "name": "nestjs-devtools",
  "displayName": "nestjs-devtools",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "nestjs-log-helper.insertDebugLog",
        "title": "NestJS Devtools: Insert debug log"
      },
      {
        "command": "nestjs-log-helper.insertLogLog",
        "title": "NestJS Devtools: Insert log log"
      },
      {
        "command": "nestjs-log-helper.insertWarnLog",
        "title": "NestJS Devtools: Insert warn log"
      },
      {
        "command": "nestjs-log-helper.insertErrorLog",
        "title": "NestJS Devtools: Insert error log"
      },
      {
        "command": "nestjs-log-helper.insertVerboseLog",
        "title": "NestJS Devtools: Insert verbose log"
      },
      {
        "command": "nestjs-log-helper.moduleSearcher",
        "title": "NestJS Devtools: Open Module Files"
      }
    ],
    "keybindings": [
      {
        "command": "nestjs-log-helper.insertDebugLog",
        "key": "cmd+l cmd+d",
        "when": "editorTextFocus && editorLangId =~ /^typescript$|^javascript$/"
      },
      {
        "command": "nestjs-log-helper.insertLogLog",
        "key": "cmd+l cmd+l",
        "when": "editorTextFocus && editorLangId =~ /^typescript$|^javascript$/"
      },
      {
        "command": "nestjs-log-helper.insertWarnLog",
        "key": "cmd+l cmd+w",
        "when": "editorTextFocus && editorLangId =~ /^typescript$|^javascript$/"
      },
      {
        "command": "nestjs-log-helper.insertErrorLog",
        "key": "cmd+l cmd+e",
        "when": "editorTextFocus && editorLangId =~ /^typescript$|^javascript$/"
      },
      {
        "command": "nestjs-log-helper.insertVerboseLog",
        "key": "cmd+l cmd+v",
        "when": "editorTextFocus && editorLangId =~ /^typescript$|^javascript$/"
      },
      {
        "command": "nestjs-log-helper.moduleSearcher",
        "key": "cmd+l cmd+m",
        "when": "editorTextFocus && editorLangId =~ /^typescript$|^javascript$/"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.19",
    "@types/vscode": "^1.118.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  }
}
